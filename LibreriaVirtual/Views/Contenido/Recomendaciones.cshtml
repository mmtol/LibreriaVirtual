<div class="reco-container">

    <div class="reco-hero">
        <h1>Recomendaciones</h1>
        <p>Descubre contenido adaptado a tus gustos y tendencias actuales</p>
    </div>

    <div class="reco-grid">

        <!-- CARD 1 -->
        <a asp-controller="Contenido"
           asp-action="Index"
           asp-route-accion="genero"
           asp-route-personal="@false"
           class="reco-card">

            <div class="reco-icon">🎭</div>
            <h2>Según tu género favorito</h2>
            <p>Explora títulos basados en el género que más has valorado.</p>
            <span class="reco-btn">Explorar</span>

        </a>

        <!-- CARD 2 -->
        <a asp-controller="Contenido"
           asp-action="Index"
           asp-route-accion="puntuacion"
           asp-route-personal="@false"
           class="reco-card">

            <div class="reco-icon">⭐</div>
            <h2>Más valorados</h2>
            <p>Descubre los contenidos con mejores puntuaciones globales.</p>
            <span class="reco-btn">Ver ranking</span>

        </a>

        <a asp-controller="Contenido"
           asp-action="Index"
           asp-route-accion="aleatorio"
           asp-route-personal="@false"
           class="reco-card">

            <div class="reco-icon">🎲</div>
            <h2>Contenido aleatorio</h2>
            <p>¿No sabes qué ver? Deja que te sorprendamos con un título aleatorio.</p>
            <span class="reco-btn">Averiguar</span>

        </a>

    </div>

</div>