@model Contenido
@{
    bool personal = (bool)ViewData["personal"];
    bool soloFavs = (bool)ViewData["favs"];
}

<div class="detalle-container">

    <div class="volver-wrapper">
        @if (!soloFavs)
        {
            <a asp-controller="Contenido" asp-action="Index" asp-route-personal=@personal asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value class="btn-volver">
                ← Volver al Catálogo
            </a>
        }
        else
        {
            <a asp-controller="Contenido" asp-action="Index" asp-route-personal=@personal asp-route-favs=@soloFavs asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value class="btn-volver">
                ← Volver al Catálogo
            </a>
        }
    </div>

    <div class="detalle-card">

        <div class="detalle-img">
            <img src="/@Model.Imagen" alt="@Model.Titulo" />
        </div>

        <div class="detalle-info">

            <h1>@Model.Titulo</h1>

            <div class="detalle-tags">
                <span class="tag tipo">@Model.Tipo</span>
                <span class="tag genero">@Model.Genero</span>
            </div>

            @if (Model.Estado == "Vista" && int.Parse(Context.User.FindFirst(ClaimTypes.NameIdentifier).Value) == Model.IdUsuario)
            {
                <div class="detalle-review">
                    <div class="rating">
                        ⭐ @Model.Puntuacion / 10
                    </div>
                    <div class="opinion">
                        "@Model.Opinion"
                    </div>
                </div>
            }

        </div>

    </div>

</div>