@using LibreriaVirtual.Helpers;

<div class="crear-container">

    <div class="volver-wrapper">
        <a asp-controller="Contenido" asp-action="Index" asp-route-personal=@true asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value class="btn-volver">
            ← Volver al Catálogo
        </a>
    </div>

    <div class="crear-hero">
        <h1>Nuevo Contenido</h1>
        <p>Añade una nueva serie o película a tu catálogo</p>
    </div>

    <div class="crear-card">

        <form id="formCrear"
              enctype="multipart/form-data"
              asp-controller="Contenido"
              asp-action="Create"
              asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value
              method="post">

            <div class="crear-preview" id="previewContainer">
                <img id="previewImg" />
            </div>

            <div class="input-group">
                <label>Título</label>
                <input type="text" name="Titulo" required />
            </div>

            <div class="input-group">
                <label>Tipo</label>
                <select name="tipo" required>
                    <option disabled selected>-- Elige el tipo --</option>
                    @foreach (Tipos tipo in Tipos.GetValues(typeof(Tipos)))
                    {
                        <option>@tipo</option>
                    }
                </select>
            </div>

            <div class="input-group">
                <label>Género</label>
                <select name="genero" required>
                    <option disabled selected>-- Elige el género --</option>
                    @foreach (Generos genero in Generos.GetValues(typeof(Generos)))
                    {
                        <option>@genero</option>
                    }
                </select>
            </div>

            <div class="custom-file-input">
                <input type="file" name="fichero" id="fileInput" accept="image/*" />
                <button type="button" onclick="document.getElementById('fileInput').click()">
                    Subir Imagen
                </button>
            </div>

            <button type="submit" class="btn-crear">
                Crear Contenido
            </button>

        </form>

    </div>

</div>

<script>

    const fileInput = document.getElementById("fileInput");
    const previewImg = document.getElementById("previewImg");
    const previewContainer = document.getElementById("previewContainer");
    const form = document.getElementById("formCrear");

    previewContainer.style.display = "none";

    fileInput.addEventListener("change", function () {
        const file = this.files[0];

        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                previewImg.src = e.target.result;
                previewContainer.style.display = "flex";
            };
            reader.readAsDataURL(file);
        }
    });

    // VALIDACIÓN FORMULARIO
    form.addEventListener("submit", function (e) {

        const titulo = document.querySelector("input[name='Titulo']").value.trim();
        const tipo = document.querySelector("select[name='tipo']").value;
        const genero = document.querySelector("select[name='genero']").value;
        const imagen = fileInput.files.length;

        if (!titulo || !tipo || !genero || imagen === 0) {

            e.preventDefault();

            Swal.fire({
                icon: 'warning',
                title: 'Campos incompletos',
                text: 'Debes rellenar todos los campos antes de crear el contenido',
                confirmButtonColor: '#4da6ff'
            });

        }

    });

</script>