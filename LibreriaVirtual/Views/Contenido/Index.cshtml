@model List<Contenido>
@using LibreriaVirtual.Helpers;

@{
    bool personal = (bool)ViewData["personal"];
}

@if (personal)
{
    <h1>Catalogo personal</h1>
}
else
{
    <h1>Catalogo publico</h1>
}

@if (!personal)
{
    <div>
        <form method="post">
            <label>Filtros</label>
            <select name="tipo">
                <option>-- Elige el tipo --</option>
                @foreach (Tipos tipo in Tipos.GetValues(typeof(Tipos)))
                {
                    <option>@tipo</option>
                }
            </select>
            <select name="genero">
                <option>-- Elige el genero --</option>
                @foreach (Generos genero in Generos.GetValues(typeof(Generos)))
                {
                    <option>@genero</option>
                }
            </select>
            <button>Aplicar</button>
        </form>
    </div>
}
else
{
    <div>
        <a asp-controller="Contenido" asp-action="Create">Nuevo</a>
    </div>
}

@if (Model != null)
{
    @foreach (Contenido contenido in Model)
    {
        if (personal)
        {
            <div>
                <img src="/@contenido.Imagen" style="width:50px"/>
                <h2>@contenido.Titulo</h2>
                <h3>@contenido.Tipo</h3>
                <h3>@contenido.Genero</h3>
                <a asp-controller="Contenido" asp-action="Details" asp-route-idcontenido=@contenido.IdContenido>
                    Detalles
                </a>
                <a href="#" onclick="marcarVisto(@contenido.IdContenido)">
                    Marcar como visto
                </a>
                <a asp-controller="Contenido" asp-action="Delete" asp-route-idcontenido=@contenido.IdContenido>
                    Eliminar
                </a>
                @if (contenido.Estado == "Vista")
                {
                    <a href="#" onclick="modificarOpinion(@contenido.IdContenido)">
                        Modificar puntuación
                    </a>
                }
            </div>
        }
        else
        {
            <div>
                <img src=@contenido.Imagen />
                <h2>@contenido.Titulo</h2>
                <h3>@contenido.Tipo</h3>
                <h3>@contenido.Genero</h3>
                <a asp-controller="Contenido" asp-action="Details" asp-route-idcontenido=@contenido.IdContenido>
                    Detalles
                </a>
                <a asp-controller="Contenido" asp-action="Apropiar" asp-route-idcontenido=@contenido.IdContenido asp-route-titulo=@contenido.Titulo asp-route-tipo=@contenido.Tipo asp-route-genero=@contenido.Genero asp-route-imagen=@contenido.Imagen>
                    Añadir al catalogo personal
                </a>
            </div>
        }
    }
}

<script>
    function marcarVisto(idContenido) {
        Swal.fire({
            title: 'Marcar como visto',
            html:
                '<input id="puntuacion" type="number" min="1" max="10" class="swal2-input" placeholder="Puntuación (1-10)">' +
                '<textarea id="opinion" class="swal2-textarea" placeholder="Escribe tu opinión"></textarea>',
            confirmButtonText: 'Guardar',
            showCancelButton: true,
            preConfirm: () => {
                const puntuacion = document.getElementById('puntuacion').value;
                const opinion = document.getElementById('opinion').value;

                if (!puntuacion || puntuacion < 1 || puntuacion > 10) {
                    Swal.showValidationMessage('Introduce una puntuación válida (1-10)');
                }

                return { puntuacion, opinion };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href =
                    '/Contenido/Ver?idcontenido=' + idContenido +
                    '&puntuacion=' + result.value.puntuacion +
                    '&opinion=' + encodeURIComponent(result.value.opinion);
            }
        });
    }

    function modificarOpinion(idContenido) {
        Swal.fire({
            title: 'Modificar puntuación',
            html:
                '<input id="puntuacion" type="number" min="1" max="10" class="swal2-input" placeholder="Nueva puntuación">' +
                '<textarea id="opinion" class="swal2-textarea" placeholder="Nueva opinión"></textarea>',
            confirmButtonText: 'Actualizar',
            showCancelButton: true,
            preConfirm: () => {
                const puntuacion = document.getElementById('puntuacion').value;
                const opinion = document.getElementById('opinion').value;

                if (!puntuacion || puntuacion < 1 || puntuacion > 10) {
                    Swal.showValidationMessage('Introduce una puntuación válida (1-10)');
                }

                return { puntuacion, opinion };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href =
                    '/Contenido/UpdateOpinion?idcontenido=' + idContenido +
                    '&puntuacion=' + result.value.puntuacion +
                    '&opinion=' + encodeURIComponent(result.value.opinion);
            }
        });
    }
</script>
