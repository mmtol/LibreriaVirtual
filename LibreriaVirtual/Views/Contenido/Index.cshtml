@model List<Contenido>
@using LibreriaVirtual.Helpers;

@{
    bool personal = (bool)ViewData["personal"];
    bool soloFavs = ViewData["favs"] != null;
    int mostrados = 0;
}

<div class="catalogo-container">

    <div class="catalogo-hero">
        @if (personal && !soloFavs)
        {
            <h1>Mi Catálogo Personal</h1>
            <p>Gestiona tus contenidos guardados y valoraciones</p>
        }
        else if (!personal)
        {
            <h1>Catálogo Público</h1>
            <p>Explora todo el contenido disponible</p>
        }
        else if (soloFavs)
        {
            <h1>Mis Favoritos</h1>
            <p>Recuerda tus contenidos favoritos para volver a verlos</p>
        }
    </div>

    @if (!personal)
    {
        <div class="filtros-card">
            <form method="post" class="filtros-form">

                <select name="tipo">
                    <option>-- Tipo --</option>
                    @foreach (Tipos tipo in Tipos.GetValues(typeof(Tipos)))
                    {
                        <option>@tipo</option>
                    }
                </select>

                <select name="genero">
                    <option>-- Género --</option>
                    @foreach (Generos genero in Generos.GetValues(typeof(Generos)))
                    {
                        <option>@genero</option>
                    }
                </select>

                <button class="btn-filtrar">Aplicar</button>

            </form>
        </div>
    }
    else if (personal && !soloFavs)
    {
        <div class="nuevo-wrapper">
            <a asp-controller="Contenido" asp-action="Create" asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value class="btn-nuevo">
                + Nuevo Contenido
            </a>
        </div>
    }

    <div class="catalogo-grid">

        @if (Model != null)
        {
            @foreach (Contenido contenido in Model)
            {
                bool mostrar = true;

                if (soloFavs && (!contenido.Favorito || !contenido.Favorito))
                {
                    mostrar = false;
                }

                if (mostrar)
                {
                    mostrados++;

                    <div class="catalogo-card">

                        <div class="card-img">
                            <img src="/@contenido.Imagen" />
                        </div>

                        <div class="card-body">

                            <h2>@contenido.Titulo</h2>

                            <div class="card-tags">
                                <span class="tag tipo">@contenido.Tipo</span>
                                <span class="tag genero">@contenido.Genero</span>
                            </div>

                            @if (personal && contenido.Estado == "Vista")
                            {
                                <div class="vista-badge">✅ Vista</div>
                            }

                            <div class="card-actions">

                                <a asp-controller="Contenido"
                                   asp-action="Details"
                                   asp-route-idcontenido="@contenido.IdContenido">
                                    Detalles
                                </a>

                                @if (personal)
                                {
                                    <a href="#" onclick="marcarVisto(@contenido.IdContenido)">
                                        Marcar como visto
                                    </a>

                                    <a href="#" onclick="confirmarEliminar(@contenido.IdContenido)">
                                        Eliminar
                                    </a>

                                    @if (contenido.Estado == "Vista")
                                    {
                                        <a href="#" onclick="modificarOpinion(@contenido.IdContenido)">
                                            Modificar puntuación
                                        </a>

                                        <a asp-controller="Contenido"
                                           asp-action="MarcarFav"
                                           asp-route-idcontenido="@contenido.IdContenido"
                                           asp-route-favs=@ViewData["favs"]
                                           asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value
                                           class="fav-btn">
                                            @(contenido.Favorito == true ? "⭐" : "☆")
                                        </a>
                                    }
                                }
                                else
                                {
                                    <a asp-controller="Contenido"
                                       asp-action="Apropiar"
                                       asp-route-titulo="@contenido.Titulo"
                                       asp-route-tipo="@contenido.Tipo"
                                       asp-route-genero="@contenido.Genero"
                                       asp-route-imagen="@contenido.Imagen"
                                       asp-route-id=@Context.User.FindFirst(ClaimTypes.NameIdentifier).Value>
                                        Añadir a mi catálogo
                                    </a>
                                }

                            </div>

                        </div>

                    </div>
                }
            }
        }

        @if (mostrados == 0)
        {
            <p class="sin-contenido">
                @if (soloFavs)
                {
                    <text>Aún no tienes contenidos favoritos ⭐</text>
                }
                else if (personal)
                {
                    <text>Aún no has añadido contenidos a tu catálogo</text>
                }
                else
                {
                    <text>No hay contenidos disponibles en el catálogo</text>
                }
            </p>
        }

    </div>

</div>

<script>

    function marcarVisto(idContenido) {

        Swal.fire({
            title: 'Marcar como visto',
            html:
                '<div class="swal-form">' +
                    '<input id="puntuacion" type="number" min="1" max="10" step="1" placeholder="Puntuación (1-10)">' +
                    '<textarea id="opinion" placeholder="Escribe tu opinión"></textarea>' +
                '</div>',
            confirmButtonText: 'Guardar',
            cancelButtonText: 'Cancelar',
            showCancelButton: true,
            focusConfirm: false,

            preConfirm: () => {

                const puntuacionInput = document.getElementById('puntuacion');
                const opinionInput = document.getElementById('opinion');

                const puntuacion = puntuacionInput.value.trim();
                const opinion = opinionInput.value.trim();

                if (puntuacion === "" || opinion === "") {
                    Swal.showValidationMessage("Debes rellenar puntuación y opinión");
                    return false;
                }

                if (!/^[0-9]+$/.test(puntuacion)) {
                    Swal.showValidationMessage("La puntuación debe ser un número entero");
                    return false;
                }

                const puntuacionNum = parseInt(puntuacion);

                if (puntuacionNum < 1 || puntuacionNum > 10) {
                    Swal.showValidationMessage("La puntuación debe estar entre 1 y 10");
                    return false;
                }

                return {
                    puntuacion: puntuacionNum,
                    opinion: opinion
                };
            }

        }).then((result) => {

            if (result.isConfirmed) {

                window.location.href =
                    '/Contenido/Ver?idcontenido=' + idContenido +
                    '&puntuacion=' + result.value.puntuacion +
                    '&opinion=' + encodeURIComponent(result.value.opinion);
            }

        });

    }



    function modificarOpinion(idContenido) {

        Swal.fire({
            title: 'Modificar puntuación',
            html:
                '<div class="swal-form">' +
                    '<input id="puntuacion" type="number" min="1" max="10" step="1" placeholder="Nueva puntuación">' +
                    '<textarea id="opinion" placeholder="Nueva opinión"></textarea>' +
                '</div>',
            confirmButtonText: 'Actualizar',
            cancelButtonText: 'Cancelar',
            showCancelButton: true,
            focusConfirm: false,

            preConfirm: () => {

                const puntuacionInput = document.getElementById('puntuacion');
                const opinionInput = document.getElementById('opinion');

                const puntuacion = puntuacionInput.value.trim();
                const opinion = opinionInput.value.trim();

                if (puntuacion === "" || opinion === "") {
                    Swal.showValidationMessage("Debes rellenar puntuación y opinión");
                    return false;
                }

                if (!/^[0-9]+$/.test(puntuacion)) {
                    Swal.showValidationMessage("La puntuación debe ser un número entero");
                    return false;
                }

                const puntuacionNum = parseInt(puntuacion);

                if (puntuacionNum < 1 || puntuacionNum > 10) {
                    Swal.showValidationMessage("La puntuación debe estar entre 1 y 10");
                    return false;
                }

                return {
                    puntuacion: puntuacionNum,
                    opinion: opinion
                };
            }

        }).then((result) => {

            if (result.isConfirmed) {

                window.location.href =
                    '/Contenido/UpdateOpinion?idcontenido=' + idContenido +
                    '&puntuacion=' + result.value.puntuacion +
                    '&opinion=' + encodeURIComponent(result.value.opinion);
            }

        });

    }

        function confirmarEliminar(idContenido) {

        Swal.fire({
            title: '¿Eliminar contenido?',
            text: 'Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#4da6ff',
            cancelButtonColor: '#aaa',
            reverseButtons: true
        }).then((result) => {

            if (result.isConfirmed) {
                window.location.href = '/Contenido/Delete?idcontenido=' + idContenido;
            }

        });

    }

</script>