@model Usuario
@{
    EstadisticasUsuario estadisticas = ViewData["estadisticas"] as EstadisticasUsuario;
}

<div class="perfil-container">

    <!-- CABECERA PERFIL -->
    <div class="perfil-header">
        <div class="perfil-img-wrapper">
            <img src="/@Model.Imagen" alt="@Model.Nombre" />
        </div>

        <div class="perfil-info">
            <h1>@Model.Nombre</h1>
            <p>@Model.Email</p>

            <a asp-action="Editar" asp-controller="Usuario" class="btn-editar">
                Editar Perfil
            </a>
        </div>
    </div>

    <!-- ESTADÍSTICAS -->
    <div class="stats-grid">

        <div class="stat-card">
            <h3>Total</h3>
            <span>@estadisticas.Total</span>
        </div>

        <div class="stat-card">
            <h3>Series</h3>
            <span>@estadisticas.Series</span>
        </div>

        <div class="stat-card">
            <h3>Películas</h3>
            <span>@estadisticas.Peliculas</span>
        </div>

        <div class="stat-card">
            <h3>Pendientes</h3>
            <span>@estadisticas.Pendientes</span>
        </div>

    </div>

</div>