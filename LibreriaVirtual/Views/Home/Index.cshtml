@model List<string>

<div class="home-hero">
    <div class="home-carousel">
        @for (int i = 0; i < Model.Count; i++)
        {
            <img src="@Model[i]" alt="Contenido" data-index="@i" />
        }
    </div>
</div>

<script>
    window.addEventListener("DOMContentLoaded", () => {
        const imgs = document.querySelectorAll(".home-carousel img");
        const delay = 4; // segundos entre cada imagen

        imgs.forEach((img, i) => {
            img.style.animationDelay = `${i * delay}s`;
        });
    });
</script>