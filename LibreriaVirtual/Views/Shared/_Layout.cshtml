<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8" />
        <title>Librería Virtual</title>
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    </head>

    <body class="layout-page">

        <div class="sidebar">
            <div class="menu">
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Usuario" asp-action="Perfil"
                    asp-route-id="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value">Perfil</a>

                <a asp-controller="Contenido" asp-action="Index"
                    asp-route-personal="true"
                    asp-route-id="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value">Catalogo Personal</a>

                <a asp-controller="Contenido" asp-action="Index"
                    asp-route-personal="false"
                    asp-route-id="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value">Catalogo Publico</a>

                <a asp-controller="Contenido" asp-action="Recomendaciones">Recomendaciones</a>

                <a asp-controller="Contenido" asp-action="Index"
                    asp-route-personal="true"
                    asp-route-favs="true"
                    asp-route-id="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value">Tus Favoritos</a>

                <a asp-controller="Account" asp-action="Logout">Cerrar Sesión</a>
            }
            </div>
        </div>

        <div class="right-zone">

            <div class="topbar">
            <a class="titulo" asp-controller="Home" asp-action="Index">LIBRERÍA VIRTUAL</a>

                <div class="perfil-burbuja">
                @if (User.Identity.IsAuthenticated)
                {
                    <img src="/@User.FindFirst("Imagen")?.Value" />
                }
                </div>
            </div>

            <div class="contenido">
                @RenderBody()
            </div>

        </div>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    </body>


</html>
